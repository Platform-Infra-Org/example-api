# --- Auth demo (app/v1/auth_demo) ---
# Downstream service called by the outbound SSO example (GET /auth-demo/downstream)
DOWNSTREAM_API_URL=https://downstream.example.com
DOWNSTREAM_ENDPOINT=/protected

# Inbound auth — GLOBAL. The app is built with general_create_app(enable_auth=True), so
# the library's AuthMiddleware protects EVERY route (except /docs, /metrics, /health,
# /openapi.json, /static, probes) once BOTH are true:
#   1) AUTH_ENABLED=true          # master switch; off by default, app boots open
#   2) exactly ONE verification material below is set
# With AUTH_ENABLED off the app is open (except /auth-demo/whoami, which has no identity
# to echo and always 401s). Enabling with no material set fails app creation (fail-fast).
# AUTH_ENABLED=true
#   AUTH_HS256_SECRET=shared-secret                 # symmetric HS256
#   AUTH_JWKS_URL=https://idp.example.com/.well-known/jwks.json   # RS256 via JWKS
#   AUTH_PUBLIC_KEY_PEM / AUTH_PUBLIC_KEY_PATH      # offline RS256
# AUTH_AUDIENCE=my-api
# AUTH_ISSUER=https://idp.example.com/
# AUTH_EXCLUDE_PATHS=["/health","/metrics",...]     # optional; extends the default excludes

# Outbound SSO (OAuth2 client_credentials) for the downstream call:
# AUTH_SSO_TOKEN_URL=https://idp.example.com/oauth/token
# AUTH_SSO_CLIENT_ID=my-service
# AUTH_SSO_CLIENT_SECRET=super-secret-value
# AUTH_SSO_SCOPE=api.read api.write
# AUTH_SSO_AUDIENCE=https://api.example.com
# AUTH_SSO_AUTH_STYLE=post

# --- Config provider / Remote Config ---
# Set CONFIG_API_URL to wire the library's enable_remote_config_api against an upstream
# Config API. The DNS routes then resolve their AWX template ids from it (keyed on the
# request's metadata coordinates). When unset, the provider is disabled and DNS falls
# back to its static conf template ids (the app still boots).
# CONFIG_API_URL=https://config-api.example.com
# CONFIG_API_REMOTE_PREFIX=/api/v1
#
# Outbound auth to the upstream (read by the library's ConfigRemoteSettings):
#   CONFIG_REMOTE_AUTH_METHOD=none      # none | bearer | sso  (use 'none' for local dev)
#   CONFIG_REMOTE_BEARER_TOKEN=...      # when method=bearer
#   CONFIG_REMOTE_SSO_TOKEN_URL=https://idp.example.com/oauth/token   # when method=sso
#   CONFIG_REMOTE_SSO_CLIENT_ID=my-service
#   CONFIG_REMOTE_SSO_CLIENT_SECRET=super-secret-value